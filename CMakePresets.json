            ],
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "warnings": {
                "dev": true
            },
            "vendor": {
                "microsoft.com/VisualStudioSettings/CMake/1.0": {
                    "hostOS": "Windows"
                }
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
