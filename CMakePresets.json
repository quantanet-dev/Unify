            "description": "Sets default generator, compiler, build and install directories",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        {
            "name": "Debug-windows-x86_64",
            "inherits": [
